# Mật khẩu vào tool (bắt buộc cho bản deploy public)
APP_PASSWORD=

# Token Haravan (Admin API) của store Bếp Ngọc Bảo — để đọc SP & cập nhật giá. KHÔNG commit.
HARAVAN_TOKEN=

# (Tuỳ chọn) Khoá ScraperAPI để render JS + xoay proxy cho web chống bot mạnh.
# Đăng ký tại https://www.scraperapi.com — nếu để trống, hệ thống fetch trực tiếp.
SCRAPER_API_KEY=

# Mã quốc gia proxy (mặc định vn)
SCRAPER_COUNTRY=vn
