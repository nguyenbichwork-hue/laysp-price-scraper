# Mật khẩu vào tool (bắt buộc cho bản deploy public)
APP_PASSWORD=

# Token Haravan (Admin API) của store Bếp Ngọc Bảo — để đọc SP & cập nhật giá. KHÔNG commit.
HARAVAN_TOKEN=

# (Tuỳ chọn) Khoá ScraperAPI để render JS + xoay proxy cho web chống bot mạnh.
# Đăng ký tại https://www.scraperapi.com — nếu để trống, hệ thống fetch trực tiếp.
SCRAPER_API_KEY=

# Mã quốc gia proxy (mặc định vn)
SCRAPER_COUNTRY=vn

# (Tuỳ chọn) Google Sheet qua Apps Script Web App — xem apps-script/README.md để cài.
# URL Web app sau khi Deploy (dạng .../macros/s/AKfy.../exec)
APPS_SCRIPT_URL=
# Chuỗi bí mật, phải TRÙNG với biến SECRET trong Code.gs
SHEET_SECRET=

# (Tuỳ chọn) Thông báo Telegram khi cập nhật giá. Tạo bot qua @BotFather lấy token;
# lấy chat id qua @userinfobot. Để trống = không gửi.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
